{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/document-version.schema.json",
  "title": "document-version",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version_id",
    "document_id",
    "revision_id",
    "parent_version_id",
    "knowledge_snapshot_id",
    "selections",
    "decision",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "version_id": {
      "type": "string",
      "pattern": "^version_[0-9A-Za-z]{8,40}$"
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "parent_version_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^version_[0-9A-Za-z]{8,40}$"
        }
      ]
    },
    "knowledge_snapshot_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^knowledge_[0-9a-f]{8,64}$"
        }
      ]
    },
    "selections": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^cand_[0-9a-f]{64}$"
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_by",
        "reason"
      ],
      "properties": {
        "selected_by": {
          "enum": [
            "user",
            "policy",
            "agent"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "published"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
