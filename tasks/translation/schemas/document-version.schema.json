{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/document-version.schema.json",
  "title": "document-version",
  "description": "DocumentVersion v2:selection manifest。selections 为唯一选择源;selection_decisions 逐 segment 审计(key 必须与 selections 完全一致)。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version_id",
    "document_id",
    "revision_id",
    "parent_version_id",
    "knowledge_snapshot_id",
    "selections",
    "selection_decisions",
    "decision",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "version_id": {
      "type": "string",
      "pattern": "^version_[0-9A-Za-z]{8,40}$"
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "parent_version_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^version_[0-9A-Za-z]{8,40}$"
        }
      ]
    },
    "knowledge_snapshot_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^knowledge_[0-9a-f]{8,64}$"
        }
      ]
    },
    "selections": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^cand_[0-9a-f]{64}$"
      }
    },
    "selection_decisions": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "selected_by",
          "outcome",
          "reason_code",
          "incumbent_candidate_id",
          "evaluation_ids"
        ],
        "properties": {
          "selected_by": {
            "enum": [
              "user",
              "policy",
              "agent"
            ]
          },
          "outcome": {
            "enum": [
              "select_challenger",
              "keep_incumbent",
              "review_required"
            ]
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          },
          "incumbent_candidate_id": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "pattern": "^cand_[0-9a-f]{64}$"
              }
            ]
          },
          "evaluation_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^eval_[0-9A-Za-z]{8,40}$"
            }
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "created_by"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "created_by": {
          "enum": [
            "user",
            "policy",
            "agent",
            "workflow"
          ]
        }
      }
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "published"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
