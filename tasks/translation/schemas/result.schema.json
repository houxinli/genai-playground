{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/result.schema.json",
  "title": "result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "task_digest",
    "producer",
    "candidates",
    "findings",
    "recommended_candidate_keys",
    "completed_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[0-9A-Za-z]{8,40}$"
    },
    "task_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{8,64}$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "model"
      ],
      "properties": {
        "type": {
          "enum": [
            "api",
            "harness",
            "human"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "result_candidate_key",
          "segment_id",
          "source_hash",
          "text"
        ],
        "properties": {
          "result_candidate_key": {
            "type": "string",
            "minLength": 1
          },
          "segment_id": {
            "type": "string",
            "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
          },
          "source_hash": {
            "type": "string",
            "pattern": "^[0-9a-f]{8,64}$"
          },
          "text": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          }
        }
      }
    },
    "recommended_candidate_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
