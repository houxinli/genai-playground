{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/entity-review.schema.json",
  "title": "entity-review",
  "description": "Entity Linking review 队列项(#83 P1b-2):抽取出的人名 proposal 经链接判定后待人工裁决。抽取输出不被信任,过 review 才晋升实体。review_id 由 proposal 本质内容寻址;status/decided_by 可更新。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "mention",
    "document_id",
    "confidence",
    "reason",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "review_id": {
      "type": "string",
      "pattern": "^review_[0-9a-f]{16,64}$"
    },
    "mention": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "segment_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
        }
      ]
    },
    "candidate_entity_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^entity_[0-9a-f]{16,64}$"
        }
      ]
    },
    "suggested_target": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "context": {
      "type": "string"
    },
    "reason": {
      "enum": [
        "low_confidence_match",
        "target_conflict",
        "new_candidate",
        "unmatched_needs_target",
        "fuzzy_match",
        "reading_match"
      ]
    },
    "status": {
      "enum": [
        "pending",
        "approved",
        "dismissed"
      ]
    },
    "decided_by": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "match_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "近似匹配(fuzzy/reading)分数;精确匹配不带此字段"
    }
  }
}
