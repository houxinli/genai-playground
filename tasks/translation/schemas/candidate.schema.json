{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/candidate.schema.json",
  "title": "candidate",
  "description": "Candidate v3:纯内容、不可变、content-addressed。producer/provenance/purpose/parent/created_at 已移入 attestation。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "document_id",
    "revision_id",
    "segment_id",
    "source_hash",
    "normalization_version",
    "text"
  ],
  "properties": {
    "schema_version": {
      "const": 3
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[0-9a-f]{64}$"
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "segment_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
    },
    "source_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{8,64}$"
    },
    "normalization_version": {
      "const": 1
    },
    "text": {
      "type": "string"
    }
  }
}
