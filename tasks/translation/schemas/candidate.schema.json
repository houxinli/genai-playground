{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/candidate.schema.json",
  "title": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "document_id",
    "revision_id",
    "segment_id",
    "source_hash",
    "text",
    "purpose",
    "parent_candidate_id",
    "producer",
    "provenance",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[0-9A-Za-z]{8,40}$"
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "segment_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
    },
    "source_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{8,64}$"
    },
    "text": {
      "type": "string"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "parent_candidate_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^cand_[0-9A-Za-z]{8,40}$"
        }
      ]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "model",
        "harness"
      ],
      "properties": {
        "type": {
          "enum": [
            "api",
            "harness",
            "human",
            "legacy"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "harness": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "task_digest",
        "result_digest",
        "result_candidate_key",
        "prompt_version",
        "recipe_id",
        "knowledge_snapshot_id"
      ],
      "properties": {
        "task_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^task_[0-9A-Za-z]{8,40}$"
            }
          ]
        },
        "task_digest": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[0-9a-f]{8,64}$"
            }
          ]
        },
        "result_digest": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[0-9a-f]{8,64}$"
            }
          ]
        },
        "result_candidate_key": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "prompt_version": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "recipe_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "knowledge_snapshot_id": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^knowledge_[0-9a-f]{8,64}$"
            }
          ]
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "producer": {
            "properties": {
              "type": {
                "enum": [
                  "api",
                  "harness"
                ]
              }
            },
            "required": [
              "type"
            ]
          }
        },
        "required": [
          "producer"
        ]
      },
      "then": {
        "properties": {
          "provenance": {
            "properties": {
              "task_id": {
                "type": "string",
                "pattern": "^task_[0-9A-Za-z]{8,40}$"
              },
              "task_digest": {
                "type": "string",
                "pattern": "^[0-9a-f]{8,64}$"
              },
              "result_digest": {
                "type": "string",
                "pattern": "^[0-9a-f]{8,64}$"
              },
              "result_candidate_key": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
