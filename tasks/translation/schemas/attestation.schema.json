{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/attestation.schema.json",
  "title": "attestation",
  "description": "Attestation:append-only 来源记录,声明某 producer 经某 provenance 产出了某 Candidate。同 Candidate 可有多条 attestation(文本等价去重)。attestation_id 确定性派生 → 同 Result/同 legacy 重放不新增。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "attestation_id",
    "candidate_id",
    "producer",
    "purpose",
    "parent_candidate_id",
    "task_id",
    "task_digest",
    "result_digest",
    "result_candidate_key",
    "legacy_label",
    "knowledge_snapshot_id",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "attestation_id": {
      "type": "string",
      "pattern": "^att_[0-9a-f]{64}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[0-9a-f]{64}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "parent_candidate_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^cand_[0-9a-f]{64}$"
        }
      ]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "model",
        "harness"
      ],
      "properties": {
        "type": {
          "enum": [
            "api",
            "harness",
            "human",
            "legacy"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "harness": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      }
    },
    "task_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^task_[0-9A-Za-z]{8,40}$"
        }
      ]
    },
    "task_digest": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8,64}$"
        }
      ]
    },
    "result_digest": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^[0-9a-f]{8,64}$"
        }
      ]
    },
    "result_candidate_key": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "legacy_label": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "knowledge_snapshot_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^knowledge_[0-9a-f]{8,64}$"
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "producer": {
            "properties": {
              "type": {
                "enum": [
                  "api",
                  "harness"
                ]
              }
            },
            "required": [
              "type"
            ]
          }
        },
        "required": [
          "producer"
        ]
      },
      "then": {
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^task_[0-9A-Za-z]{8,40}$"
          },
          "task_digest": {
            "type": "string",
            "pattern": "^[0-9a-f]{8,64}$"
          },
          "result_digest": {
            "type": "string",
            "pattern": "^[0-9a-f]{8,64}$"
          },
          "result_candidate_key": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
