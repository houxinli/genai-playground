{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/annotation.schema.json",
  "title": "annotation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "annotation_id",
    "document_id",
    "revision_id",
    "segment_id",
    "target_candidate_id",
    "type",
    "comment",
    "created_by",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "annotation_id": {
      "type": "string",
      "pattern": "^annotation_[0-9A-Za-z]{8,40}$"
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "segment_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
    },
    "target_candidate_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^cand_[0-9a-f]{64}$"
        }
      ]
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "comment": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
