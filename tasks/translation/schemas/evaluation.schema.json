{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/evaluation.schema.json",
  "title": "evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "candidate_id",
    "evaluator",
    "verdict",
    "findings",
    "scores",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "evaluation_id": {
      "type": "string",
      "pattern": "^eval_[0-9A-Za-z]{8,40}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^cand_[0-9A-Za-z]{8,40}$"
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "version"
      ],
      "properties": {
        "type": {
          "enum": [
            "rule",
            "llm",
            "human"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verdict": {
      "enum": [
        "pass",
        "fail"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "error",
              "warning",
              "info"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          }
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
