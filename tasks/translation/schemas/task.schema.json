{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/task.schema.json",
  "title": "task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "task_type",
    "document_id",
    "revision_id",
    "segment_ids",
    "source_hashes",
    "context_digest",
    "knowledge_snapshot_id",
    "constraints",
    "existing_candidate_ids",
    "annotation_ids",
    "expected_result_schema"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[0-9A-Za-z]{8,40}$"
    },
    "task_type": {
      "enum": [
        "translate",
        "annotate",
        "review",
        "compare",
        "repair",
        "entity_link",
        "terminology_review"
      ]
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "segment_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
      }
    },
    "source_hashes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{8,64}$"
      }
    },
    "context_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{8,64}$"
    },
    "knowledge_snapshot_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^knowledge_[0-9a-f]{8,64}$"
        }
      ]
    },
    "constraints": {
      "type": "object"
    },
    "existing_candidate_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^cand_[0-9a-f]{64}$"
      },
      "uniqueItems": true
    },
    "annotation_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^annotation_[0-9A-Za-z]{8,40}$"
      },
      "uniqueItems": true
    },
    "expected_result_schema": {
      "type": "integer",
      "minimum": 1
    }
  }
}
