{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/houxinli/genai-playground/tasks/translation/schemas/document-revision.schema.json",
  "title": "document-revision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_id",
    "revision_id",
    "source",
    "metadata",
    "segments"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "document_id": {
      "type": "string",
      "pattern": "^(pixiv|fanbox):[A-Za-z0-9_-]+:[A-Za-z0-9_-]+$"
    },
    "revision_id": {
      "type": "string",
      "pattern": "^rev_[0-9a-f]{8,64}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "creator_id",
        "source_id",
        "url"
      ],
      "properties": {
        "provider": {
          "enum": [
            "pixiv",
            "fanbox"
          ]
        },
        "creator_id": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "segment_id",
          "ordinal",
          "kind",
          "source_text",
          "source_hash"
        ],
        "properties": {
          "segment_id": {
            "type": "string",
            "pattern": "^rev_[0-9a-f]{8,64}:[0-9]{6}:[0-9a-f]{4,64}$"
          },
          "ordinal": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "type": "string",
            "pattern": "^(body|metadata\\.[a-z_]+)$"
          },
          "source_text": {
            "type": "string"
          },
          "source_hash": {
            "type": "string",
            "pattern": "^[0-9a-f]{8,64}$"
          }
        }
      }
    }
  }
}
