#!/usr/bin/env bash
# Pre-push hook: run the fast offline test suites before pushing.
# Install with: bash scripts/install-git-hooks.sh
#
# These suites are sub-second; blocking a push on a red suite is cheap insurance.
# (CI re-runs them authoritatively; this is just a fast local gate.)

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# Prefer the project's conda env (tests import transformers/openai/yaml/etc).
if [ "${CONDA_DEFAULT_ENV:-}" = "llm" ]; then
  PY=(python)
elif command -v conda >/dev/null 2>&1; then
  PY=(conda run -n llm python)
else
  PY=(python)
fi

export TRANSLATION_FORCE_SIMPLE_ESTIMATOR=1
export TRANSLATION_SKIP_REMOTE_TOKENIZER=1

echo "pre-push: running translation test suite..."
# 与 CI 保持一致:pytest 统跑(unittest discover 不执行 pytest 风格用例)
if ! "${PY[@]}" -m pytest tasks/translation/src -q >/tmp/prepush_translation.log 2>&1; then
  echo "pre-push: translation tests FAILED (see /tmp/prepush_translation.log). Push aborted." >&2
  tail -20 /tmp/prepush_translation.log >&2
  exit 1
fi

echo "pre-push: running sunday-movies offline tests..."
if ! ( cd tasks/sunday-movies/src && "${PY[@]}" -m unittest ratings.tests.utils_test ratings.tests.test_aggregator \
    collectors.amc_test collectors.fandango_test ratings.tests.rottentomatoes_fetcher_test ) >/tmp/prepush_sunday.log 2>&1; then
  echo "pre-push: sunday-movies tests FAILED (see /tmp/prepush_sunday.log). Push aborted." >&2
  tail -20 /tmp/prepush_sunday.log >&2
  exit 1
fi

echo "pre-push: all fast tests passed."
exit 0
