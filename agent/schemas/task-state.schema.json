{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Task State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "title",
    "status",
    "branch",
    "objective",
    "github",
    "scope",
    "context_files",
    "decisions",
    "open_questions",
    "blockers",
    "plan",
    "next_action",
    "validation",
    "known_unrelated_changes",
    "last_checkpoint",
    "next_task"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9._-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "planned",
        "active",
        "blocked",
        "complete",
        "cancelled"
      ]
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue",
        "pull_request"
      ],
      "properties": {
        "issue": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "pull_request": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in",
        "out"
      ],
      "properties": {
        "in": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "out": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "context_files": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "purpose",
          "required"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "reason",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "active",
              "superseded"
            ]
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "attempts",
          "needs",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "attempts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "needs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "enum": [
              "active",
              "resolved"
            ]
          }
        }
      }
    },
    "plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "depends_on",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "blocked",
              "skipped"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "acceptance": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "next_action": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "step_id",
            "instruction",
            "acceptance"
          ],
          "properties": {
            "step_id": {
              "type": "string",
              "minLength": 1
            },
            "instruction": {
              "type": "string",
              "minLength": 1
            },
            "acceptance": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_commands",
        "last_results"
      ],
      "properties": {
        "required_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "last_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "command",
              "status",
              "summary",
              "timestamp"
            ],
            "properties": {
              "command": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "enum": [
                  "passed",
                  "failed",
                  "not_run"
                ]
              },
              "summary": {
                "type": "string"
              },
              "timestamp": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "known_unrelated_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "last_checkpoint": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "checkpoint_id",
            "timestamp",
            "agent",
            "summary",
            "observed_head"
          ],
          "properties": {
            "checkpoint_id": {
              "type": "string",
              "minLength": 1
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "agent": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "observed_head": {
              "type": "string",
              "minLength": 7
            }
          }
        }
      ]
    },
    "next_task": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "issue",
            "task_id",
            "branch"
          ],
          "properties": {
            "issue": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "task_id": {
              "type": "string",
              "minLength": 3
            },
            "branch": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
