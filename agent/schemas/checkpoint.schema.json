{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Task Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checkpoint_id",
    "task_id",
    "timestamp",
    "agent",
    "branch",
    "observed_head",
    "step_id",
    "summary",
    "files",
    "worktree",
    "validation",
    "blockers",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "observed_head": {
      "type": "string",
      "minLength": 7
    },
    "step_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "summary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clean",
        "task_changes",
        "unrelated_changes"
      ],
      "properties": {
        "clean": {
          "type": "boolean"
        },
        "task_changes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "unrelated_changes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "status",
          "summary"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "step_id",
            "instruction",
            "acceptance"
          ],
          "properties": {
            "step_id": {
              "type": "string",
              "minLength": 1
            },
            "instruction": {
              "type": "string",
              "minLength": 1
            },
            "acceptance": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    }
  }
}
